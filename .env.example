# clawgate configuration — every setting is optional.
# Copy to `.env` and edit as needed.

# ── Auth mode ────────────────────────────────────────────────
# `chatgpt` (default): use your ChatGPT Pro/Plus subscription via
#                      OAuth. Run `clawgate login` first.
# `apikey`           : use a standard OpenAI (or compatible) API key.
# AUTH_MODE=chatgpt

# ── apikey mode ──────────────────────────────────────────────
# Required when AUTH_MODE=apikey
# OPENAI_API_KEY=sk-...
# Optional OpenAI-compatible base URL (only used in apikey mode)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Model mapping ────────────────────────────────────────────
# Anthropic model name → OpenAI model name
#   *opus*    → BIG_MODEL
#   *sonnet*  → MID_MODEL
#   *haiku*   → SMALL_MODEL
#
# In ChatGPT mode the Codex backend only accepts these models:
#   gpt-5.1-codex-max, gpt-5.1-codex-mini, gpt-5.2-codex,
#   gpt-5.3-codex, gpt-5.4
# To use any other model (gpt-4o, gpt-4o-mini, etc.), switch to
# AUTH_MODE=apikey and supply OPENAI_API_KEY.
# BIG_MODEL=gpt-5.4
# MID_MODEL=gpt-5.3-codex
# SMALL_MODEL=gpt-5.2-codex

# ── Fast mode ────────────────────────────────────────────────
# Sends service_tier: "priority" in API requests.
# FAST_MODE=0

# ── Reasoning effort ─────────────────────────────────────────
# Applies only to reasoning models (gpt-5*, o1, o3, o4).
# One of: none, minimal, low, medium, high, xhigh
# Matches Codex CLI's model_reasoning_effort values verbatim.
# Per-request Anthropic `thinking` still wins if a client sends it.
# REASON=high
# (REASONING_EFFORT=high also accepted as an alias)

# ── Web search ───────────────────────────────────────────────
# Claude Code's WebSearch tool works in ChatGPT mode only.
# In apikey mode the tool is silently dropped (no server-side
# search endpoint available).

# ── Server ───────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8082

# ── Debug ────────────────────────────────────────────────────
# Set DEBUG=1 to log incoming/outgoing payloads to stderr.
# DEBUG=1
