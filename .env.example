# clawgate configuration — every setting is optional.
# Copy to `.env` and edit as needed.

# ── Auth mode ────────────────────────────────────────────────
# `chatgpt` (default): use your ChatGPT Pro/Plus subscription via
#                      OAuth. Run `./clawgate login` first.
# `apikey`           : use a standard OpenAI (or compatible) API key.
# AUTH_MODE=chatgpt

# ── apikey mode ──────────────────────────────────────────────
# Required when AUTH_MODE=apikey
# OPENAI_API_KEY=sk-...
# Optional OpenAI-compatible base URL (only used in apikey mode)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Model mapping ────────────────────────────────────────────
# Anthropic model name → OpenAI model name
#   *haiku*           → SMALL_MODEL
#   *sonnet*, *opus*  → BIG_MODEL
# BIG_MODEL=gpt-5.4
# SMALL_MODEL=gpt-5.4-mini

# ── Server ───────────────────────────────────────────────────
# PORT=8082

# ── Debug ────────────────────────────────────────────────────
# Set DEBUG=1 to log incoming/outgoing payloads to stderr.
# DEBUG=1
